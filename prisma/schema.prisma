// GVIDON TOUR data model.
// Localized text fields (Json) hold {ru, en, kk} strings.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TourKind {
  TOUR
  EXCURSION
}

enum MediaKind {
  PHOTO
  VIDEO
}

model Tour {
  id         String    @id @default(cuid())
  slug       String    @unique
  kind       TourKind  @default(TOUR)
  region     Json // {ru,en,kk} — badge on the card
  title      Json
  desc       Json
  duration   Json // "2 дня" / "2 days" / "2 күн"
  days       Int
  priceFrom  Int // numeric ₸ value for filters/sorting
  priceText  Json // "от 120 000 ₸"
  city       String? // direction slug (astana, almaty, ...)
  season     String?
  restType   String?
  image      String
  imagePos   String?
  featured   Boolean   @default(false)
  sortOrder  Int       @default(0)
  published  Boolean   @default(true)
  details    Json? // future excursion page: program, included, map, tips...
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Category {
  id        String @id @default(cuid())
  slug      String @unique
  name      Json
  icon      String
  sortOrder Int    @default(0)
  tours     Tour[]
}

model Direction {
  id        String  @id @default(cuid())
  slug      String  @unique
  name      Json
  image     String?
  sortOrder Int     @default(0)
}

model Review {
  id        String   @id @default(cuid())
  author    String
  text      Json
  rating    Int      @default(5)
  photo     String?
  videoUrl  String?
  date      DateTime @default(now())
  published Boolean  @default(true)
}

model GalleryItem {
  id        String    @id @default(cuid())
  kind      MediaKind @default(PHOTO)
  src       String // always an image: the photo itself, or the video's poster/thumbnail
  videoUrl  String? // set when kind = VIDEO; playable src (mp4) or YouTube/Vimeo URL
  caption   Json
  span      String?
  sortOrder Int       @default(0)
  published Boolean   @default(true)
}

model Achievement {
  id        String @id @default(cuid())
  title     Json
  image     String
  sortOrder Int    @default(0)
}

enum LeadStatus {
  NEW
  DONE
}

/** Booking/contact request from the public site form. */
model Lead {
  id        String     @id @default(cuid())
  name      String
  phone     String?
  email     String?
  tour      String? // free-text tour title the visitor picked
  message   String?
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  login        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       Json
  excerpt     Json
  content     Json // array of localized paragraphs: [{ru,en,kk}, ...]
  image       String
  publishedAt DateTime @default(now())
  sortOrder   Int      @default(0)
  published   Boolean  @default(true)
}

// Brute-force / spam brake, shared by every server instance.
// Key is "<scope>:<ip>"; a row is reused across windows rather than deleted
// on every hit, and expired leftovers are swept occasionally (rate-limit.ts).
model RateLimit {
  key       String   @id
  count     Int      @default(1)
  expiresAt DateTime

  @@index([expiresAt])
}
